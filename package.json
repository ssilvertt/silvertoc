{
  "name": "telegram-bot-base",
  "version": "1.0.0",
  "description": "Базовый Telegram-бот на Node.js + TypeScript",
  "main": "dist/index.js",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.15.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
